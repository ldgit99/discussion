# Supabase — research.md §9.6 + .claude/skills/supabase-schema-patterns
# Supabase 프로젝트 생성 후 Dashboard > Project Settings > API에서 복사
NEXT_PUBLIC_SUPABASE_URL=https://YOUR_PROJECT.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=eyJ...

# 서버 사이드 전용 — 절대 클라이언트에 노출 금지
SUPABASE_SERVICE_ROLE_KEY=eyJ...

# OpenAI — research.md §9.1 (Gemini 미사용 확정, 메모리 project-ai-provider)
OPENAI_API_KEY=sk-...

# 선택: 모델 명시 (기본은 lib/ai/provider.ts에서)
# OPENAI_MODEL=gpt-4o-mini

# Public 사이트 URL (Vercel 자동 주입, 로컬은 명시)
NEXT_PUBLIC_SITE_URL=http://localhost:3000
